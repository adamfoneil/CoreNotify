<svg class="mr-4 h-6 w-6 text-teal-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
@{ 
    var paths = Imagery[this.Image];
    foreach (var path in paths)
    {
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@path" />
    }
}        
</svg>

